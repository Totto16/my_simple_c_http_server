{
	"extends": "@tsconfig/strictest/tsconfig.json",
	"compilerOptions": {
		"noPropertyAccessFromIndexSignature": false,
		"noImplicitOverride": true,
		"noImplicitAny": true,
		"module": "es2022",
		"target": "es2022",
		"lib": [
			"ES2022",
		],
		"outDir": "build",
		"rootDir": ".",
		"sourceMap": false,
		"checkJs": false,
		"allowJs": false,
		"strict": true,
		"strictNullChecks": true,
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"noUnusedLocals": false,
		"types": ["node"]
	},
	"exclude": [
		"node_modules/"
	],
	"files": [
		"index.ts",
	],
	"include": [
		"src/**/*.ts"
	],
	"ts-node": {
		"compilerOptions": {
			"module": "CommonJS",
		},
		"files": true
	}
}
